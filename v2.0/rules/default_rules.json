[
  {
    "id": "sentinelops-auth-bruteforce",
    "title": "Brute Force Login Pattern",
    "description": "Multiple failed authentication events from one source address.",
    "status": "experimental",
    "level": "High",
    "enabled": true,
    "confidence": 90,
    "logsource": {"product": "windows", "category": "authentication"},
    "match": {"all": [{"field": "status", "operator": "equals", "value": "failed"}]},
    "threshold": {"count": 5, "groupBy": "sourceIp", "windowSeconds": 300},
    "suppresses": ["sentinelops-single-auth-failure"],
    "mitre": {"id": "T1110.001", "name": "Password Guessing", "tactic": "Credential Access"},
    "tags": ["attack.credential_access", "attack.t1110.001"],
    "falsepositives": ["Authorized password testing", "Misconfigured service accounts"]
  },
  {
    "id": "sentinelops-powershell-suspicious",
    "title": "Suspicious PowerShell Execution",
    "description": "PowerShell command contains an encoded, download, credential, or defense-bypass indicator.",
    "status": "experimental",
    "level": "High",
    "enabled": true,
    "confidence": 85,
    "logsource": {"product": "windows", "category": "process_creation"},
    "match": {"all": [{"field": "command", "operator": "regex", "value": "(-enc(?:odedcommand)?\\s+|invoke-expression|\\biex\\b|downloadstring|invoke-webrequest|frombase64string|amsiutils|invoke-mimikatz|sekurlsa|bypass)"}]},
    "mitre": {"id": "T1059.001", "name": "PowerShell", "tactic": "Execution"},
    "tags": ["attack.execution", "attack.t1059.001"],
    "falsepositives": ["Administrative automation using encoded scripts"]
  },
  {
    "id": "sentinelops-privilege-activity",
