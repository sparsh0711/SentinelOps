[
  {
    "id": "sentinelops-auth-bruteforce",
    "title": "Brute Force Login Pattern",
    "description": "Multiple failed authentication events from one source address.",
    "status": "experimental",
    "level": "High",
    "enabled": true,
    "confidence": 90,
    "logsource": {"product": "windows", "category": "authentication"},
    "match": {
      "all": [
        {"field": "status", "operator": "equals", "value": "failed"}
      ]
    },
    "threshold": {"count": 5, "groupBy": "sourceIp", "windowSeconds": 300},
    "suppresses": ["sentinelops-single-auth-failure"],
    "mitre": {"id": "T1110.001", "name": "Password Guessing", "tactic": "Credential Access"},
    "tags": ["attack.credential_access", "attack.t1110.001"],
    "falsepositives": ["Authorized password testing", "Misconfigured service accounts"]
  },
  {
    "id": "sentinelops-powershell-suspicious",
